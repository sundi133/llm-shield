# LLM Shield Environment Configuration
# Copy this file to .env and fill in your actual values

# RunPod Configuration (for hosted deployments)
RUNPOD_TOKEN=your-runpod-api-token-here
RUNPOD_HOST=https://your-endpoint.api.runpod.ai

# Shield Admin Configuration
SHIELD_ADMIN_KEY=your-shield-admin-key-here

# Redis Configuration (optional - for multi-tenant setups)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# Test Configuration (optional)
TENANT_ID=your-test-tenant-id
TENANT_API_KEY=your-tenant-api-key
AGENT_KEY=your-agent-key

# OpenAI Configuration (optional - for LLM validation)
OPENAI_API_KEY=your-openai-key-here

# Additional Environment Variables
# DEBUG=true
# LOG_LEVEL=info