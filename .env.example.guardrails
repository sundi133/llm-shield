# LLM Shield Guardrails Testing Environment Variables
# Copy this file to .env and fill in your actual values

# RunPod/API Authentication Token
RUNPOD_TOKEN=rpa_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Alternative auth token variable name
AUTH_TOKEN=your_auth_token_here

# API Key for tenant access
API_KEY=tenant-YYYYMMDDHHMMSS-XXXXXX-key-XXXXXX
# Alternative API key variable name
X_API_KEY=your_x_api_key_here

# Tenant ID for testing
TENANT_ID=tenant-YYYYMMDDHHMMSS-XXXXXX

# Optional: Base URL (defaults to placeholder in script)
BASE_URL=https://your-llm-shield-endpoint.com